# Copy to `server/.env`. The API, Knex, `db:create`, and the Vite client (via envDir) read from here.

NODE_ENV=development
PORT=3000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=fb_soccer_quiz_game

# Instant Games app secret (server-side only). Required for signed player info in production.
META_APP_SECRET=

# Optional public API URL for docs / client hints
API_BASE_URL=http://127.0.0.1:3000

# Set to 1 for local dev without Facebook: send header X-Dev-Player-Id: test-player-1
DEV_AUTH_BYPASS=1

# Client (Vite) — prefix with VITE_
VITE_API_URL=http://127.0.0.1:3000
VITE_DEV_PLAYER_ID=dev-player-local
VITE_DEV_PORT=5173
