{
  "name": "intellectual-game-for-facebook",
  "private": true,
  "workspaces": [
    "server",
    "client-admin"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test -w server",
    "dev:server": "npm run dev -w server",
    "dev:admin:ui": "npm run dev -w client-admin",
    "dev:admin": "sh -c 'npm run dev:server & npm run dev:admin:ui & wait'",
    "dev": "npm run dev:admin",
    "dev:admin:full": "npm run dev:admin",
    "dev:all": "npm run dev:admin",
    "db:create": "npm run db:create -w server",
    "migrate": "npm run migrate -w server",
    "migrate:latest": "npm run migrate:latest -w server",
    "seed": "npm run seed -w server",
    "lint": "npm run lint --workspaces --if-present"
  }
}
